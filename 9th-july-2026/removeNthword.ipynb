   "source": [
    "## Removing the nth word from the given list\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "47a87ab8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "['a', 'b', 'c', 'a']\n"
     ]
    }
   ],
   "source": [
    "my_list=[\"a\",\"b\",\"c\",\"a\",\"a\"]\n",
    "word=\"a\"\n",
    "n=2\n",
    "count=0\n",
    "for i in range(0,len(my_list)-1):\n",
    "    if(my_list[i]==word):\n",
    "        count=count+1\n",
    "        if(count>=n):\n",
    "            del my_list[i]\n",
    "print(my_list)"
   ]
  },
